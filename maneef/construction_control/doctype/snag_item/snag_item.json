{
    "doctype": "DocType",
    "name": "Snag Item",
    "module": "Construction Control",
    "custom": 0,
    "istable": 1,
    "editable_grid": 1,
    "track_changes": 1,
    "fields": [
        {
            "fieldname": "description",
            "fieldtype": "Text",
            "label": "Snag Description",
            "reqd": 1,
            "in_list_view": 1,
            "columns": 4
        },
        {
            "fieldname": "location",
            "fieldtype": "Data",
            "label": "Location / Zone",
            "reqd": 1,
            "in_list_view": 1,
            "columns": 2
        },
        {
            "fieldname": "discipline",
            "fieldtype": "Select",
            "label": "Discipline",
            "options": "Architectural\nStructural\nMEP\nInterior\nLandscape\nGeneral",
            "in_list_view": 1,
            "columns": 2
        },
        {
            "fieldname": "priority",
            "fieldtype": "Select",
            "label": "Priority",
            "options": "Low\nMedium\nHigh\nCritical",
            "default": "Medium",
            "reqd": 1,
            "in_list_view": 1,
            "columns": 1
        },
        {
            "fieldname": "status",
            "fieldtype": "Select",
            "label": "Status",
            "options": "Open\nIn Progress\nResolved\nClosed\nDisputed",
            "default": "Open",
            "reqd": 1,
            "in_list_view": 1,
            "columns": 1
        },
        {
            "fieldname": "assigned_contractor",
            "fieldtype": "Link",
            "label": "Assigned Contractor",
            "options": "Supplier",
            "in_list_view": 1,
            "columns": 2
        },
        {
            "fieldname": "raised_date",
            "fieldtype": "Date",
            "label": "Raised Date",
            "default": "Today",
            "reqd": 1
        },
        {
            "fieldname": "due_date",
            "fieldtype": "Date",
            "label": "Due Date"
        },
        {
            "fieldname": "resolved_date",
            "fieldtype": "Date",
            "label": "Resolved Date",
            "depends_on": "eval:doc.status == 'Resolved' || doc.status == 'Closed'"
        },
        {
            "fieldname": "photo",
            "fieldtype": "Attach Image",
            "label": "Photo"
        },
        {
            "fieldname": "resolution_notes",
            "fieldtype": "Small Text",
            "label": "Resolution Notes",
            "depends_on": "eval:doc.status == 'Resolved' || doc.status == 'Closed'"
        },
        {
            "fieldname": "source_svr",
            "fieldtype": "Link",
            "label": "Source SVR",
            "options": "Site Visit Report",
            "read_only": 1
        }
    ],
    "permissions": []
}
