{
    "doctype": "DocType",
    "name": "Site Visit Report",
    "module": "Construction Control",
    "custom": 1,
    "is_submittable": 1,
    "autoname": "naming_series:",
    "track_changes": 1,
    "fields": [
        {
            "fieldname": "naming_series",
            "fieldtype": "Select",
            "label": "Naming Series",
            "options": "SVR-.YYYY.-.####"
        },
        {
            "fieldname": "visit_info_section",
            "fieldtype": "Section Break",
            "label": "Visit Information"
        },
        {
            "fieldname": "assigned_engineer",
            "fieldtype": "Link",
            "options": "Employee",
            "label": "Assigned Engineer",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "visit_date",
            "fieldtype": "Date",
            "label": "Visit Date",
            "reqd": 1,
            "default": "Today",
            "in_list_view": 1
        },
        {
            "fieldname": "visit_type",
            "fieldtype": "Select",
            "options": "Initial Audit\nBIM Survey\nCoordination Meeting\nQuality Inspection\nRoutine Monitoring\nSnagging Round",
            "label": "Visit Type",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "complexity_level",
            "fieldtype": "Select",
            "options": "Standard\nHigh Complexity\nOut-of-Town",
            "label": "Complexity Level",
            "reqd": 1
        },
        {
            "fieldname": "column_break_project",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "project",
            "fieldtype": "Link",
            "options": "Project",
            "label": "Project",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "task",
            "fieldtype": "Link",
            "options": "Task",
            "label": "Linked Task"
        },
        {
            "fieldname": "visit_start_time",
            "fieldtype": "Time",
            "label": "Visit Start Time"
        },
        {
            "fieldname": "visit_end_time",
            "fieldtype": "Time",
            "label": "Visit End Time"
        },
        {
            "fieldname": "financial_section",
            "fieldtype": "Section Break",
            "label": "Cost & Billing"
        },
        {
            "fieldname": "is_billable",
            "fieldtype": "Check",
            "label": "Is Billable",
            "default": "0"
        },
        {
            "fieldname": "column_break_fin",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "visit_cost",
            "fieldtype": "Currency",
            "label": "Visit Cost / Billable Amount",
            "depends_on": "eval:doc.is_billable == 1"
        },
        {
            "fieldname": "attendees_section",
            "fieldtype": "Section Break",
            "label": "Attendees"
        },
        {
            "fieldname": "attendees",
            "fieldtype": "Table",
            "label": "Attendees",
            "options": "SVR Attendee"
        },
        {
            "fieldname": "reporting_section",
            "fieldtype": "Section Break",
            "label": "Observations & Findings"
        },
        {
            "fieldname": "remarks",
            "fieldtype": "Text Editor",
            "label": "Remarks & Observations"
        },
        {
            "fieldname": "next_steps",
            "fieldtype": "Text Editor",
            "label": "Next Steps & Recommendations"
        },
        {
            "fieldname": "contractor_log_section",
            "fieldtype": "Section Break",
            "label": "Contractor Activity Log"
        },
        {
            "fieldname": "contractor_log",
            "fieldtype": "Table",
            "label": "Contractor Log",
            "options": "SVR Contractor Log"
        },
        {
            "fieldname": "issues_section",
            "fieldtype": "Section Break",
            "label": "Issues Raised"
        },
        {
            "fieldname": "issues_raised",
            "fieldtype": "Table",
            "label": "Issues Raised",
            "options": "SVR Issue"
        },
        {
            "fieldname": "photos_section",
            "fieldtype": "Section Break",
            "label": "Site Photos"
        },
        {
            "fieldname": "photos",
            "fieldtype": "Table",
            "label": "Photos",
            "options": "SVR Photo"
        }
    ],
    "permissions": [
        {
            "role": "Site Engineer",
            "read": 1, "write": 1, "create": 1, "delete": 1
        },
        {
            "role": "Project Manager",
            "read": 1, "write": 1, "create": 1, "submit": 1
        },
        {
            "role": "Managing Partner",
            "read": 1, "write": 1, "create": 1,
            "submit": 1, "cancel": 1, "amend": 1
        },
        {
            "role": "System Manager",
            "read": 1, "write": 1, "create": 1, "delete": 1,
            "submit": 1, "cancel": 1, "amend": 1
        }
    ]
}
