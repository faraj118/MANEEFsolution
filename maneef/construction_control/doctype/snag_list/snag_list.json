{
    "doctype": "DocType",
    "name": "Snag List",
    "module": "Construction Control",
    "custom": 0,
    "autoname": "naming_series:",
    "title_field": "project",
    "track_changes": 1,
    "fields": [
        {
            "fieldname": "naming_series",
            "fieldtype": "Select",
            "label": "Series",
            "options": "SL-.YYYY.-.####",
            "default": "SL-.YYYY.-.####"
        },
        {
            "fieldname": "project",
            "fieldtype": "Link",
            "label": "Project",
            "options": "Project",
            "reqd": 1,
            "in_list_view": 1,
            "in_standard_filter": 1
        },
        {
            "fieldname": "status",
            "fieldtype": "Select",
            "label": "Status",
            "options": "Active\nClosed",
            "default": "Active",
            "in_list_view": 1
        },
        {
            "fieldname": "col_break_1",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "open_critical_count",
            "fieldtype": "Int",
            "label": "Open Critical Snags",
            "read_only": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "total_open_count",
            "fieldtype": "Int",
            "label": "Total Open Snags",
            "read_only": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "snags_section",
            "fieldtype": "Section Break",
            "label": "Snag Items"
        },
        {
            "fieldname": "snags",
            "fieldtype": "Table",
            "label": "Snags",
            "options": "Snag Item",
            "reqd": 0
        },
        {
            "fieldname": "notes",
            "fieldtype": "Small Text",
            "label": "Notes"
        }
    ],
    "permissions": [
        {
            "role": "Site Engineer",
            "read": 1, "write": 1, "create": 1
        },
        {
            "role": "Project Manager",
            "read": 1, "write": 1, "create": 1, "delete": 1
        },
        {
            "role": "Managing Partner",
            "read": 1, "write": 1, "create": 1, "delete": 1
        },
        {
            "role": "System Manager",
            "read": 1, "write": 1, "create": 1, "delete": 1
        }
    ]
}
