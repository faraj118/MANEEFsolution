{
    "doctype": "DocType",
    "module": "Construction Control",
    "custom": 1,
    "is_submittable": 1,
    "autoname": "naming_series:",
    "track_changes": 1,
    "fields": [
        {
            "fieldname": "naming_series",
            "fieldtype": "Select",
            "label": "Naming Series",
            "options": "RFI-.YYYY.-.####"
        },
        {
            "fieldname": "project",
            "fieldtype": "Link",
            "options": "Project",
            "label": "Project",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "subject",
            "fieldtype": "Data",
            "label": "Subject / Query Title",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "status",
            "fieldtype": "Select",
            "label": "Status",
            "options": "Open\nUnder Review\nClosed",
            "in_list_view": 1
        },
        {
            "fieldname": "details_section",
            "fieldtype": "Section Break",
            "label": "Query Details"
        },
        {
            "fieldname": "raised_by",
            "fieldtype": "Link",
            "options": "User",
            "label": "Raised By"
        },
        {
            "fieldname": "query",
            "fieldtype": "Text Editor",
            "label": "Query / Request Details",
            "reqd": 1
        },
        {
            "fieldname": "variation_impact_section",
            "fieldtype": "Section Break",
            "label": "Variation Impact (Commercial)"
        },
        {
            "fieldname": "has_cost_impact",
            "fieldtype": "Check",
            "label": "Has Cost Impact?"
        },
        {
            "fieldname": "column_break_impact",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "has_schedule_impact",
            "fieldtype": "Check",
            "label": "Has Schedule Impact?"
        },
        {
            "fieldname": "is_billable",
            "fieldtype": "Check",
            "label": "Is Billable",
            "default": 1
        },
        {
            "fieldname": "non_billable_justification",
            "fieldtype": "Small Text",
            "label": "Non-Billable Justification",
            "depends_on": "eval:doc.is_billable==0"
        },
        {
            "fieldname": "resolution_section",
            "fieldtype": "Section Break",
            "label": "Resolution"
        },
        {
            "fieldname": "resolution",
            "fieldtype": "Text Editor",
            "label": "Resolution / Answer"
        }
    ],
    "permissions": [
        {
            "role": "Site Engineer",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1
        },
        {
            "role": "Project Manager",
            "read": 1,
            "write": 1,
            "create": 1
        }
    ],
    "name": "RFI Record"
}