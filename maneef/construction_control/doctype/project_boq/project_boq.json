{
    "doctype": "DocType",
    "name": "Project BOQ",
    "module": "Construction Control",
    "custom": 0,
    "is_submittable": 1,
    "autoname": "naming_series:",
    "track_changes": 1,
    "fields": [
        {
            "fieldname": "naming_series",
            "fieldtype": "Select",
            "label": "Naming Series",
            "options": "BOQ-.YYYY.-.####"
        },
        {
            "fieldname": "project",
            "fieldtype": "Link",
            "options": "Project",
            "label": "Project",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "prepared_by",
            "fieldtype": "Link",
            "options": "User",
            "label": "Prepared By",
            "default": "__user",
            "in_list_view": 1
        },
        {
            "fieldname": "preparation_date",
            "fieldtype": "Date",
            "label": "Preparation Date",
            "default": "Today"
        },
        {
            "fieldname": "revision",
            "fieldtype": "Data",
            "label": "Revision",
            "default": "R0",
            "in_list_view": 1
        },
        {
            "fieldname": "items_section",
            "fieldtype": "Section Break",
            "label": "BOQ Items"
        },
        {
            "fieldname": "items",
            "fieldtype": "Table",
            "options": "Project BOQ Item",
            "label": "Items",
            "reqd": 1
        },
        {
            "fieldname": "totals_section",
            "fieldtype": "Section Break",
            "label": "Totals"
        },
        {
            "fieldname": "total_amount",
            "fieldtype": "Currency",
            "label": "Total Amount",
            "read_only": 1,
            "in_list_view": 1
        }
    ],
    "permissions": [
        {
            "role": "Project Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 0,
            "submit": 1,
            "cancel": 0
        },
        {
            "role": "Managing Partner",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "submit": 1,
            "cancel": 1
        }
    ]
}
