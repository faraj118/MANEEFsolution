{
    "doctype": "DocType",
    "name": "Daily Progress Report",
    "module": "Construction Control",
    "custom": 0,
    "is_submittable": 1,
    "autoname": "naming_series:",
    "track_changes": 1,
    "fields": [
        {
            "fieldname": "naming_series",
            "fieldtype": "Select",
            "label": "Naming Series",
            "options": "DPR-.YYYY.-.MM.-.####"
        },
        {
            "fieldname": "project",
            "fieldtype": "Link",
            "options": "Project",
            "label": "Project",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "date",
            "fieldtype": "Date",
            "label": "Date",
            "reqd": 1,
            "in_list_view": 1,
            "default": "Today"
        },
        {
            "fieldname": "weather",
            "fieldtype": "Select",
            "label": "Weather Conditions",
            "options": "Clear\nCloudy\nRain\nExtreme Heat\nSandstorm"
        },
        {
            "fieldname": "site_manager",
            "fieldtype": "Link",
            "options": "Employee",
            "label": "Site Manager",
            "in_list_view": 1
        },
        {
            "fieldname": "manpower_section",
            "fieldtype": "Section Break",
            "label": "Site Manpower"
        },
        {
            "fieldname": "manpower_log",
            "fieldtype": "Table",
            "options": "DPR Manpower",
            "label": "Manpower Log"
        },
        {
            "fieldname": "equipment_section",
            "fieldtype": "Section Break",
            "label": "Site Equipment"
        },
        {
            "fieldname": "equipment_log",
            "fieldtype": "Table",
            "options": "DPR Equipment",
            "label": "Equipment Log"
        },
        {
            "fieldname": "work_executed_section",
            "fieldtype": "Section Break",
            "label": "Work Executed"
        },
        {
            "fieldname": "work_executed_today",
            "fieldtype": "Text Editor",
            "label": "Work Executed Today",
            "reqd": 1
        },
        {
            "fieldname": "delays_issues",
            "fieldtype": "Text Editor",
            "label": "Delays & Issues"
        }
    ],
    "permissions": [
        {
            "role": "Site Engineer",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 0,
            "submit": 1,
            "cancel": 0
        },
        {
            "role": "Project Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "submit": 1,
            "cancel": 1
        }
    ]
}
