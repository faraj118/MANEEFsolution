{
  "doctype": "DocType",
  "name": "Project Charter",
  "module": "Crm Commercial",
  "autoname": "naming_series:",
  "custom": 1,
  "fields": [
    {
      "fieldname": "naming_series",
      "fieldtype": "Select",
      "label": "Naming Series",
      "options": "PC-.YYYY.-.####"
    },
    {
      "fieldname": "charter_name",
      "fieldtype": "Data",
      "label": "Charter Name",
      "reqd": 1
    },
    {
      "fieldname": "customer",
      "fieldtype": "Link",
      "label": "Customer",
      "options": "Customer",
      "reqd": 1
    },
    {
      "fieldname": "project_manager",
      "fieldtype": "Link",
      "label": "Project Manager",
      "options": "User"
    },
    {
      "fieldname": "bim_standards",
      "fieldtype": "Select",
      "label": "BIM Standards",
      "options": "ISO 19650\nAIA G202\nNone"
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "opportunity",
      "fieldtype": "Link",
      "label": "Opportunity",
      "options": "Opportunity"
    },
    {
      "fieldname": "sales_order",
      "fieldtype": "Link",
      "label": "Sales Order",
      "options": "Sales Order"
    },
    {
      "fieldname": "project",
      "fieldtype": "Link",
      "label": "Project",
      "options": "Project",
      "description": "Linked ERPNext Project (auto-created on submit)"
    },
    {
      "fieldname": "section_break_2",
      "fieldtype": "Section Break",
      "label": "Project Timeline & Budget"
    },
    {
      "fieldname": "start_date",
      "fieldtype": "Date",
      "label": "Estimated Start Date"
    },
    {
      "fieldname": "end_date",
      "fieldtype": "Date",
      "label": "Estimated End Date"
    },
    {
      "fieldname": "column_break_3",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "total_budget",
      "fieldtype": "Currency",
      "label": "Total Project Budget",
      "options": "currency"
    },
    {
      "fieldname": "project_priority",
      "fieldtype": "Select",
      "label": "Project Priority",
      "options": "Low\nMedium\nHigh\nCritical",
      "default": "Medium",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "risk_level",
      "fieldtype": "Select",
      "label": "Risk Level",
      "options": "Low\nMedium\nHigh",
      "default": "Medium"
    },
    {
      "fieldname": "payment_terms",
      "fieldtype": "Link",
      "label": "Payment Terms",
      "options": "Payment Terms Template"
    },
    {
      "fieldname": "budget_breakdown",
      "fieldtype": "Table",
      "label": "Budget Breakdown",
      "options": "Budget Breakdown Item"
    },
    {
      "fieldname": "section_break_4",
      "fieldtype": "Section Break",
      "label": "Scope & Assumptions"
    },
    {
      "fieldname": "description",
      "fieldtype": "Long Text",
      "label": "Project Overview / Objectives"
    },
    {
      "fieldname": "quality_gates",
      "fieldtype": "Check",
      "label": "Quality Gates Required",
      "default": 1
    },
    {
      "fieldname": "section_break_commercial",
      "fieldtype": "Section Break",
      "label": "Commercial Decision"
    },
    {
      "fieldname": "go_no_go_decision",
      "fieldtype": "Select",
      "label": "GO/NO-GO Decision",
      "options": "Pending\nGo\nNo Go\nConditional Go",
      "default": "Pending",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "custom_contract_status",
      "fieldtype": "Select",
      "label": "Contract Status",
      "options": "Draft\nUnder Review\nNegotiation\nSigned\nTerminated",
      "default": "Draft"
    },
    {
      "fieldname": "column_break_commercial",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "custom_projected_margin",
      "fieldtype": "Percent",
      "label": "Projected Margin (%)"
    },
    {
      "fieldname": "section_break_5",
      "fieldtype": "Section Break",
      "label": "Technical Task Briefs (Cairo/Production)"
    },
    {
      "fieldname": "custom_task_briefs",
      "fieldtype": "Table",
      "label": "Task Briefs",
      "options": "Task Brief"
    },
    {
      "fieldname": "amended_from",
      "fieldtype": "Link",
      "label": "Amended From",
      "options": "Project Charter",
      "print_hide": 1,
      "read_only": 1
    },
    {
      "fieldname": "risk_assessment_section",
      "fieldtype": "Section Break",
      "label": "Risk Assessment"
    },
    {
      "fieldname": "linked_risk_assessment",
      "fieldtype": "Link",
      "label": "Linked Risk Assessment",
      "options": "Risk Assessment",
      "read_only": 1
    },
    {
      "fieldname": "risk_assessment_status",
      "fieldtype": "Select",
      "label": "Risk Assessment Status",
      "options": "Not Started\nIn Progress\nCompleted",
      "default": "Not Started",
      "read_only": 1
    },
    {
      "fieldname": "custom_payment_risk_rating",
      "fieldtype": "Select",
      "label": "Payment Risk Rating",
      "options": "Low\nMedium\nHigh\nUnacceptable",
      "read_only": 1
    },
    {
      "fieldname": "custom_commercial_risk_rating",
      "fieldtype": "Select",
      "label": "Commercial Risk Rating",
      "options": "Green\nAmber\nRed",
      "read_only": 1
    },
    {
      "fieldname": "custom_duration_risk_rating",
      "fieldtype": "Select",
      "label": "Duration Risk Rating",
      "options": "Green\nAmber\nRed\nCritical",
      "read_only": 1
    },
    {
      "fieldname": "custom_total_payment_risk_score",
      "fieldtype": "Int",
      "label": "Total Payment Risk Score",
      "read_only": 1
    },
    {
      "fieldname": "custom_total_commercial_risk_score",
      "fieldtype": "Int",
      "label": "Total Commercial Risk Score",
      "read_only": 1
    },
    {
      "fieldname": "custom_total_duration_risk_score",
      "fieldtype": "Int",
      "label": "Total Duration Risk Score",
      "read_only": 1
    },
    {
      "fieldname": "custom_gate_status",
      "fieldtype": "Select",
      "label": "Gate Status",
      "options": "Gate 1\nGate 2\nGate 3\nComplete",
      "default": "Gate 1",
      "read_only": 1
    }
  ],
  "property_setters": [
    {
      "property": "sidebar_include",
      "fieldname": "project",
      "value": "1"
    },
    {
      "property": "sidebar_include",
      "fieldname": "customer",
      "value": "1"
    },
    {
      "property": "sidebar_include",
      "fieldname": "start_date",
      "value": "1"
    },
    {
      "property": "sidebar_include",
      "fieldname": "end_date",
      "value": "1"
    },
    {
      "property": "sidebar_include",
      "fieldname": "total_budget",
      "value": "1"
    },
    {
      "property": "sidebar_include",
      "fieldname": "project_priority",
      "value": "1"
    },
    {
      "property": "sidebar_include",
      "fieldname": "risk_level",
      "value": "1"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1,
      "amend": 1
    },
    {
      "role": "Project Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1,
      "cancel": 1,
      "amend": 1
    }
  ],
  "is_submittable": 1
}