{
    "doctype": "DocType",
    "name": "Project Variation Order",
    "module": "Crm Commercial",
    "custom": 0,
    "is_submittable": 1,
    "autoname": "naming_series:",
    "track_changes": 1,
    "fields": [
        {
            "fieldname": "naming_series",
            "fieldtype": "Select",
            "label": "Naming Series",
            "options": "VO-.YY.-.####"
        },
        {
            "fieldname": "project",
            "fieldtype": "Link",
            "options": "Project",
            "label": "Project",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "customer",
            "fieldtype": "Link",
            "options": "Customer",
            "label": "Customer",
            "fetch_from": "project.customer",
            "read_only": 1
        },
        {
            "fieldname": "variation_type",
            "fieldtype": "Select",
            "options": "Scope Addition\nScope Reduction\nTime Extension Only",
            "label": "Variation Type",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "financial_impact_section",
            "fieldtype": "Section Break",
            "label": "Financial Impact"
        },
        {
            "fieldname": "original_budget",
            "fieldtype": "Currency",
            "label": "Original Contracted Fee",
            "read_only": 1,
            "fetch_from": "project.custom_contracted_fee"
        },
        {
            "fieldname": "variation_amount",
            "fieldtype": "Currency",
            "label": "Variation Amount",
            "description": "Use negative amount for Scope Reductions"
        },
        {
            "fieldname": "new_total_budget",
            "fieldtype": "Currency",
            "label": "New Total Contracted Fee",
            "read_only": 1
        },
        {
            "fieldname": "schedule_impact_section",
            "fieldtype": "Section Break",
            "label": "Schedule Impact"
        },
        {
            "fieldname": "original_end_date",
            "fieldtype": "Date",
            "label": "Original Expected End Date",
            "read_only": 1,
            "fetch_from": "project.expected_end_date"
        },
        {
            "fieldname": "requested_days_extension",
            "fieldtype": "Int",
            "label": "Requested Days Extension"
        },
        {
            "fieldname": "new_end_date",
            "fieldtype": "Date",
            "label": "New Expected End Date",
            "read_only": 1
        },
        {
            "fieldname": "justification_section",
            "fieldtype": "Section Break",
            "label": "Justification"
        },
        {
            "fieldname": "justification",
            "fieldtype": "Text Editor",
            "label": "Detailed Justification"
        },
        {
            "fieldname": "amended_by",
            "fieldtype": "Link",
            "options": "User",
            "label": "Amended By",
            "hidden": 1
        }
    ],
    "permissions": [
        {
            "role": "Project Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 0,
            "submit": 1,
            "cancel": 0
        },
        {
            "role": "Managing Partner",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "submit": 1,
            "cancel": 1
        }
    ]
}
